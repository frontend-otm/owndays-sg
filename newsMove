    <script>
      $(document).ready(function () {
        $('.body-move__styles__product-list ul').each(function () {
          var $ul = $(this);
          var $layout = $ul.closest('.body-move__styles__product-layout');
          var $count = $layout.find('.body-move__styles__product-slide-count');

          // Store references to arrows
          var $prevArrow = $layout.find('.move-arrow--prev');
          var $nextArrow = $layout.find('.move-arrow--next');

          // If arrows don't exist, create them
          if ($prevArrow.length === 0 || $nextArrow.length === 0) {
            $prevArrow = $('<button/>', {
              class: 'move-arrow move-arrow--prev',
              'aria-label': 'Previous',
            }).append(
              '<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M15.41 7.41 14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>'
            );

            $nextArrow = $('<button/>', {
              class: 'move-arrow move-arrow--next',
              'aria-label': 'Next',
            }).append(
              '<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M8.59 16.59 13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>'
            );

            $layout.append($prevArrow, $nextArrow);
          }

          var settings = {
            infinite: false,
            dots: false,
            variableWidth: true,
            centerMode: true,
            arrows: true, // Enable arrows by default
            prevArrow: $prevArrow, // Use our custom arrows
            nextArrow: $nextArrow,
            adaptiveHeight: true,
            waitForAnimate: false,
            swipeToSlide: true,
            touchThreshold: 12,
            responsive: [
              {
                breakpoint: 767,
                settings: {
                  slidesToShow: 1,
                  slidesToScroll: 1,
                  centerMode: false,
                  variableWidth: false,
                  infinite: true,
                  arrows: false,
                  dots: false,
                  adaptiveHeight: true,
                },
              },
            ],
          };

          // Add custom slider styles
          var style = document.createElement('style');
          style.textContent = `
            .slick-disabled {
              cursor: default;
              pointer-events: none;
            }

            .slick-disabled.move-arrow--prev{
              border: 1px solid #fff;
              filter: invert(1);
            }
            /* Mobile slider styles */
            @media (max-width: 767px) {
              .move-arrow {
                display: none !important;
              }
              .body-move__styles__product-list .slick-slide {
                margin: 0 7px !important;
                transition: padding 0.3s ease;
              }
              .body-move__styles__product-list > .slick-list .slick-slide {
                width: 330px !important;
                height: 200px;
                padding: 0 10px;
              }
                .body-move__styles__product-list img {
                width: 100%;
                max-width: 310px;
                height: auto;
                display: block;
                margin: 0 auto;
                }
          `;
          document.head.appendChild(style);

          // Initialize the slider
          $ul.slick(settings);

          // Update counter and arrow states
          function updateCounter() {
            var currentSlide = $ul.slick('slickCurrentSlide') + 1;
            var totalSlides = $ul.slick('getSlick').slideCount;
            $count.text(currentSlide + ' / ' + totalSlides);

            // Update arrow states
            if (currentSlide === 1) {
              $prevArrow.addClass('slick-disabled');
            } else {
              $prevArrow.removeClass('slick-disabled');
            }

            if (currentSlide === totalSlides) {
              $nextArrow.addClass('slick-disabled');
            } else {
              $nextArrow.removeClass('slick-disabled');
            }
          }

          // Set up event listeners
          $ul.on('init afterChange', updateCounter);
          $prevArrow.add($nextArrow).on('click', updateCounter);

          // Initialize the counter
          updateCounter();
        });
      });
    </script>
    <script>
      // Color switching to mirror BodyMove.jsx behavior
      $(function () {
        $('.body-move__styles__products').each(function () {
          var $product = $(this);
          var productNumber = $product.attr('data-product-number');
          var $layout = $product.find('.body-move__styles__product-layout');
          var $ul = $layout.find('.body-move__styles__product-list ul');
          var $count = $layout.find('.body-move__styles__product-slide-count');
          var $codeSpan = $layout.find('.body-move__styles__product-details-code span:last-child');
          var $prevArrow = $layout.find('.move-arrow--prev');
          var $nextArrow = $layout.find('.move-arrow--next');

          function pad2(n) {
            return String(n).padStart(2, '0');
          }

          $product
            .find('.body-move__styles__product-details-colors li button')
            .each(function (idx) {
              $(this).on('click', function () {
                var colorCode = 'C' + (idx + 1); // index → C1/C2/C3/C4 like React
                var $slides = $ul.find('li img');
                var total = $slides.length;

                // swap all slide images to the selected color
                $slides.each(function (i, img) {
                  var number = pad2(i + 1);
                  var newSrc =
                    'https://static.lenskart.com/owndays/img/move/products/' +
                    productNumber +
                    '/' +
                    productNumber +
                    '_' +
                    colorCode +
                    '_' +
                    number +
                    '.webp';
                  // pre-load then swap to avoid flicker
                  var testImg = new Image();
                  testImg.onload = function () {
                    img.src = newSrc;
                  };
                  testImg.onerror = function () {
                    img.src = img.src;
                  };
                  testImg.src = newSrc;
                });

                // update product code display
                if ($codeSpan.length) {
                  $codeSpan.text(colorCode);
                }

                // update selected state
                var $lis = $product.find('.body-move__styles__product-details-colors li');
                $lis.attr('data-color-selected', 'false');
                $lis.eq(idx).attr('data-color-selected', 'true');

                // reset slider to first and refresh counter/arrows
                try {
                  $ul.slick('slickGoTo', 0, true);
                } catch (e) {}
                if ($count.length) {
                  $count.text('1 / ' + total);
                }
                if ($prevArrow.length) {
                  $prevArrow.addClass('slick-disabled');
                }
                if ($nextArrow.length && total > 1) {
                  $nextArrow.removeClass('slick-disabled');
                }
              });
            });
        });
      });
    </script>
